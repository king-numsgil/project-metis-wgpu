{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "moduleResolution": "bundler",
    "module": "Preserve",
    // This config type-checks only; `index.d.ts` is generated by `napi build`,
    // never by tsc. `allowImportingTsExtensions` matches the root config and the
    // way Bun actually resolves these tests, and it requires `noEmit`.
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["@types/bun"]
  },
  "include": ["."],
  "exclude": ["node_modules", "bench", "__test__"]
}
